{
  "useTabs": false,
  "singleQuote": false,
  "trailingComma": "none",
  "printWidth": 100,
  "plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": "*.svelte",
      "options": {
        "parser": "svelte",
        "bracketSameLine": true,
        "printWidth": 128,
        "singleAttributePerLine": false
      }
    }
  ],
  "tailwindStylesheet": "./src/routes/layout.css"
}
