{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aether-flux",
  "version": "0.1.0",
  "identifier": "io.github.alfredclark.aether-flux",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../build",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "Aether Flux",
        "width": 1280,
        "height": 800,
        "minWidth": 1280,
        "minHeight": 800,
        "focus": true,
        "center": true,
        "devtools": true,
        "resizable": true,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; media-src 'self' asset: http://asset.localhost blob:; img-src 'self' asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/**", "$APPDATA/**", "$APPLOCALDATA/**", "$TEMP/**"]
      }
    }
  },
  "bundle": {
    "publisher": "Alfred Clark",
    "homepage": "https://github.com/AlfredClark",
    "copyright": "Copyright © 2026 Alfred Clark. All rights reserved.",
    "license": "GPL-3.0",
    "licenseFile": "../LICENSE",
    "category": "Utility",
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
